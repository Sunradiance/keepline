# Keepline — plug 3 APIs and go
# cp .env.example .env && npm run setup && npm run dev

# 1. LLM (required) — Groq recommended: https://console.groq.com/
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# 2. Tavily — vendor pricing benchmarks: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# 3. Serper — Google search for negotiation intel: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

KEEPLINE_HOST=0.0.0.0
KEEPLINE_PORT=8792
FLASK_DEBUG=False